---
import Container from "@components/Container.astro";
import { SITE, SOCIALS } from "@consts";
---

<footer>
  <Container>
    <div class="site-footer">
      {SOCIALS.map((social, index) => (
        <Fragment>
          {index > 0 && <span class="site-separator" aria-hidden="true">■</span>}
          <a href={social.HREF} target="_blank" rel="noreferrer" aria-label={`${SITE.NAME} on ${social.NAME}`}>
            {social.NAME}
          </a>
        </Fragment>
      ))}
      <span class="site-separator" aria-hidden="true">■</span>
      <a href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
        email
      </a>
    </div>
  </Container>
</footer>
